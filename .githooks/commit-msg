#!/usr/bin/env sh
# Enforces Conventional Commits: https://www.conventionalcommits.org

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Ignore merge commits, fixup!, and squash! commits
case "$commit_msg" in
  Merge*|Revert*|fixup!*|squash!*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|test|chore|ci|build|revert)(\(.+\))?(!)?: .{1,100}'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "  Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected: <type>(<scope>): <description>"
  echo "  Example:  feat(auth): add biometric lock support"
  echo ""
  echo "  Allowed types: feat, fix, docs, style, refactor, test, chore, ci, build, revert"
  echo ""
  echo "  Your message: $commit_msg"
  echo ""
  exit 1
fi

exit 0
